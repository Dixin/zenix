---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="联系" description="联系方式">
  <div class="bg-slate-50 dark:bg-[#0c0c0f] border-b border-slate-200 dark:border-slate-800 py-16 md:py-24 transition-colors">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">联系</h1>
      <p class="text-xl text-slate-600 dark:text-slate-400">
        了解CulturesPro的公司简介。
      </p>
    </div>
  </div>
  
</BaseLayout>
